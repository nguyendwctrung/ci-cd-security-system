# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Generated reports (but preserve directory structure with .gitkeep)
reports/*
!reports/.gitkeep
reports/history/*
!reports/history/.gitkeep

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# OS-specific files
Thumbs.db
.DS_Store
*.app

# Temporary and build files
*.tmp
*.log
tempUploads/
build/
dist/
*.egg-info/
.eggs/

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# Package management
*.egg
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Type-checking and linting caches
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/

# Jupyter Notebooks (if used for analysis)
.ipynb_checkpoints/
*.ipynb

# Secrets and API keys
*.pem
*.key
*.p12
secrets.json

# LLM / scanner logs
llm_analyzer.log
security_scan.log

# Miscellaneous
*.bak
*.orig
.env.local
.env.*.local
